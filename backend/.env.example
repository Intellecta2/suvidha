# Environment Configuration Example
# Copy this file to .env and customize for your deployment

# Server Configuration
PORT=5000
NODE_ENV=development
HOST=localhost

# Frontend Configuration
VITE_API_URL=http://localhost:5000

# Database Configuration (using JSON, no external DB needed)
DB_TYPE=json
DB_PATH=./data

# Feature Flags
ENABLE_OFFLINE_MODE=true
ENABLE_ACCESSIBILITY=true
ENABLE_ADMIN_PANEL=true

# Multilingual Support
SUPPORTED_LANGUAGES=en,hi,ta,te,ka,ml

# Authentication
OTP_VALIDITY_MINUTES=10
OTP_LENGTH=6
SESSION_TIMEOUT_MINUTES=30

# API Rate Limiting (for production)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging (for production)
LOG_LEVEL=info
LOG_FILE=./logs/api.log

# Security (for production)
CORS_ORIGIN=http://localhost:5173
JWT_SECRET=your-secret-key-here-change-in-production

# Payment Gateway (optional, for production)
PAYMENT_GATEWAY=razorpay
RAZORPAY_KEY_ID=your-key-here
RAZORPAY_KEY_SECRET=your-secret-here

# SMS Service (for production OTP delivery)
SMS_PROVIDER=aws-sns
AWS_SNS_REGION=ap-south-1
AWS_SNS_SENDER_ID=JANSETU

# Email Service (for notifications)
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=your-api-key-here
SENDER_EMAIL=notifications@jansetu.gov.in

# Analytics
GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X
ENABLE_ANALYTICS=true

# Deployment Environment (development, staging, production)
ENVIRONMENT=development

# Municipality Configuration
MUNICIPALITY_NAME=Sample Corporation
MUNICIPALITY_CODE=MC001
STATE=Delhi
STATE_CODE=DL
